# Variables de entorno para el prototipo FoodDash.
# Copia este archivo a `.env` y completa la key de DeepSeek.
# (NO commitear el .env real: ya esta en .gitignore)

# DeepSeek (API OpenAI-compatible en https://api.deepseek.com)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
# Modelo: deepseek-chat (V3, rapido) o deepseek-reasoner (R1, razonamiento)
DEEPSEEK_MODEL=deepseek-v4-flash
